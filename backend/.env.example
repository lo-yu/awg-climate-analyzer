# ─── AWG Climate Analyzer — Environment Variables ───────────────────────────
#
# Copy this file to .env and fill in your values.
# The app runs in DEMO MODE (mock weather data) without an API key.
#
# OpenWeatherMap API Key
# Get your free key at: https://openweathermap.org/api
# Free tier supports 1000 calls/day — sufficient for this app
#
OPENWEATHER_API_KEY=your_api_key_here
